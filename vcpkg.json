{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "squarebob-rs",
  "version-string": "0.1.0",
  "description": "Squarebob media encoder FFmpeg dependency pin",
  "homepage": "https://github.com/ssoj13/squarebob-rs",
  "license": "MIT",
  "dependencies": [
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "swresample",
        "swscale",
        "nvcodec"
      ],
      "platform": "windows | linux"
    },
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "swresample",
        "swscale"
      ],
      "platform": "osx"
    }
  ]
}
