# base64 of developer_id_application.p12
APPLE_CERTIFICATE_P12=

# password from openssl pkcs12 -export
APPLE_CERTIFICATE_PASSWORD=

# Apple Developer Team ID
APPLE_TEAM_ID=

# App Store Connect API Key ID
APPLE_API_KEY_ID=

# App Store Connect Issuer ID
APPLE_API_ISSUER_ID=

# base64 of AuthKey_XXXXXXXXXX.p8
APPLE_API_KEY_P8=

# temporary CI keychain password
KEYCHAIN_PASSWORD=